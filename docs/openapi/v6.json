        ],
        "responses": {
          "200": {
            "description": "Array of recommended videos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Video" }
                }
              }
            }
          }
        }
      }
    },

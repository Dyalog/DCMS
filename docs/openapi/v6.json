{
  "openapi": "3.0.3",
  "info": {
    "title": "Dyalog Content Management System",
    "version": "6.0.0",
    "description": "CRUD and admin endpoints for the Dyalog CMS. CRUD and admin endpoints are authenticated by X-API-Key header. The API key can be generated in the admin interface."
  },
  "servers": [],
  "security": [],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "Event": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "type": { "type": "string" },
          "start": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
          "end": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
          "url_slug": { "type": "string" }
        }
      },
      "Video": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "description": { "type": "string" },
          "event": { "type": "string" },
          "event_shortname": { "type": "string" },
          "presented_at": { "type": "string", "format": "date-time", "description": "Year and month of presentation as YYYY-MM-DD hh:mm:ss" },
          "presenter": { "type": "string", "description": "Comma-separated list of presenter names" },
          "published_at": { "type": "string", "format": "date-time", "description": "YouTube video publish date as YYYY-MM-DD hh:mm:ss" },
          "thumbnail": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string" },
          "youtube_id": { "type": "string" }
        }
      },
      "PaginatedVideos": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "The URL for this endpoint" },
          "per_page": { "type": "integer" },
          "current_page": { "type": "integer" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Video" }
          },
          "from": { "type": "integer", "description": "Ordinal number of the first result on this page" },
          "to": { "type": "integer", "description": "Ordinal number of the last result on this page" },
          "total": { "type": "integer", "description": "Total count of results for this query" },
          "first_page": { "type": "integer" },
          "last_page": { "type": "integer" },
          "first_page_url": { "type": "string" },
          "prev_page_url": { "type": "string" },
          "next_page_url": { "type": "string" },
          "last_page_url": { "type": "string" },
          "links": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PaginationLink"
            }
          }
        }
      },
      "PaginationLink": {
        "type": "object",
        "description": "Link objects describe numbered, previous and next buttons used on paginated results pages",
        "properties": {
          "active": { "type": "boolean" },
          "label": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "CrudItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" }
        },
        "additionalProperties": true,
        "description": "A table row. Fields beyond 'id' depend on the specific table."
      },
      "LoggingStatus": {
        "type": "object",
        "properties": {
          "on": { "type": "boolean" }
        }
      },
      "ProfilingStatus": {
        "type": "object",
        "properties": {
          "on": { "type": "boolean" }
        }
      },
      "ProfileEntry": {
        "type": "object",
        "properties": {
          "fn_name": { "type": "string" },
          "line_no": { "type": "integer" },
          "n_calls": { "type": "integer" },
          "exclusive_time": { "type": "number", "format": "double", "description": "Time spent in this function, excluding time spent in called functions" },
          "inclusive_time": { "type": "number", "format": "double", "description": "Time spent in this function, including time spent in called functions" }
        }
      }
    }
  },
  "paths": {
    "/version": {
      "get": {
        "summary": "Get API version",
        "operationId": "getVersion",
        "responses": {
          "200": {
            "description": "Version string",
            "content": {
              "application/json": {
                "schema": { "type": "string", "example": "6.0.0" }
              }
            }
          }
        }
      }
    },
    "/presenters": {
      "get": {
        "summary": "List presenter names",
        "operationId": "getPresenters",
        "responses": {
          "200": {
            "description": "Array of presenter names",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "/events": {
      "get": {
        "summary": "List events",
        "operationId": "getEvents",
        "parameters": [
          {
            "name": "has_videos",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "Filter to events that have videos"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Event" }
                }
              }
            }
          }
        }
      }
    },
    "/videos": {
      "get": {
        "summary": "List or search videos",
        "operationId": "getVideos",
        "description": "Returns all videos, or filtered/paginated results when query parameters are provided. When per_page and page are specified, the response is a paginated envelope rather than a plain array.",
        "parameters": [
          {
            "name": "event_shortname",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by event shortname"
          },
          {
            "name": "presenter",
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            },
            "style": "form",
            "explode": false,
            "description": "Filter by presenter IDs"
          },
          {
            "name": "search",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Search terms"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Number of results per page (enables pagination)"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Page number (enables pagination)"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of videos, or a paginated envelope when per_page and page are specified",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Video" }
                    },
                    { "$ref": "#/components/schemas/PaginatedVideos" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/videos/{youtube_id}": {
      "get": {
        "summary": "Get a single video by YouTube ID",
        "operationId": "getVideo",
        "parameters": [
          {
            "name": "youtube_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A single video object",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Video" }
              }
            }
          }
        }
      }
    },
    "/videos/{youtube_id}/recommended": {
      "get": {
        "summary": "Get recommended videos for a given video",
        "operationId": "getRecommendedVideos",
        "parameters": [
          {
            "name": "youtube_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }

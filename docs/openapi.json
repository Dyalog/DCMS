{
  "openapi": "3.0.3",
  "info": {
    "title": "Dyalog Content Management System",
    "version": "4.0.0",
    "description": "REST API for the Dyalog Content Management System.\n\nPublic read endpoints serve cached, joined views of the data. Authenticated `/table/*` endpoints provide direct CRUD access to individual database tables. Admin endpoints control logging, profiling, and cache refresh.\n\nAll `/table/*` and `/admin/*` endpoints require an `X-API-Key` header. API keys are generated in the admin interface."
  },
  "servers": [
    { "url": "/v4", "description": "API v4 base path" }
  ],
  "tags": [
    { "name": "System",  "description": "Version and health." },
    { "name": "Videos",  "description": "Public read-only video endpoints (cached, joined views)." },
    { "name": "Events",  "description": "Public read-only event endpoints." },
    { "name": "Presenters", "description": "Public read-only presenter endpoints." },
    { "name": "Table CRUD", "description": "Authenticated CRUD on individual database tables." },
    { "name": "Admin",   "description": "Administrative operations: cache refresh, logging, profiling." }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "parameters": {
      "TableId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Row ID"
      },
      "YoutubeId": {
        "name": "youtube_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "11-character YouTube video ID"
      },
      "PerPage": {
        "name": "per_page",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "default": 20 },
        "description": "Number of results per page."
      },
      "Page": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "default": 1 },
        "description": "Page number."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error":   { "type": "string", "description": "Machine-readable error code" },
          "message": { "type": "string", "description": "Human-readable description" }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id":       { "type": "integer" },
          "title":    { "type": "string" },
          "type":     { "type": "string" },
          "start":    { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
          "end":      { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
          "url_slug": { "type": "string" }
        }
      },
      "Video": {
        "type": "object",
        "properties": {
          "category":       { "type": "string" },
          "description":    { "type": "string" },
          "event":          { "type": "string" },
          "event_shortname": { "type": "string" },
          "presented_at":   { "type": "string", "format": "date-time", "description": "Presentation date as YYYY-MM-DD hh:mm:ss" },
          "presenter":      { "type": "string", "description": "Comma-separated list of presenter names" },
          "published_at":   { "type": "string", "format": "date-time", "description": "YouTube publish date as YYYY-MM-DD hh:mm:ss" },
          "thumbnail":      { "type": "string" },
          "title":          { "type": "string" },
          "url":            { "type": "string" },
          "youtube_id":     { "type": "string" }
        }
      },
      "PaginationLink": {
        "type": "object",
        "description": "Describes a numbered, previous, or next button for paginated results.",
        "properties": {
          "active": { "type": "boolean" },
          "label":  { "type": "string" },
          "url":    { "type": "string", "nullable": true }
        }
      },
      "PaginatedVideos": {
        "type": "object",
        "properties": {
          "path":           { "type": "string", "description": "The URL for this endpoint" },
          "per_page":       { "type": "integer" },
          "current_page":   { "type": "integer" },
          "data":           { "type": "array", "items": { "$ref": "#/components/schemas/Video" } },
          "from":           { "type": "integer", "description": "Ordinal of the first result on this page" },
          "to":             { "type": "integer", "description": "Ordinal of the last result on this page" },
          "total":          { "type": "integer", "description": "Total count of results for this query" },
          "first_page":     { "type": "integer" },
          "last_page":      { "type": "integer" },
          "first_page_url": { "type": "string" },
          "prev_page_url":  { "type": "string", "nullable": true },
          "next_page_url":  { "type": "string", "nullable": true },
          "last_page_url":  { "type": "string" },
          "links":          { "type": "array", "items": { "$ref": "#/components/schemas/PaginationLink" } }
        }
      },
      "CrudItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" }
        },
        "additionalProperties": true,
        "description": "A table row. Fields beyond 'id' depend on the specific table."
      },
      "ToggleStatus": {
        "type": "object",
        "properties": {
          "on": { "type": "boolean" }
        },
        "required": ["on"]
      },
      "ProfileEntry": {
        "type": "object",
        "properties": {
          "fn_name":        { "type": "string" },
          "line_no":        { "type": "integer" },
          "n_calls":        { "type": "integer" },
          "exclusive_time": { "type": "number", "format": "double", "description": "Time in this function, excluding called functions" },
          "inclusive_time": { "type": "number", "format": "double", "description": "Time in this function, including called functions" }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid API key.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "unauthorized", "message": "Missing or invalid X-API-Key header" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "not_found", "message": "The requested resource does not exist" }
          }
        }
      },
      "NoContent": {
        "description": "Deleted successfully. No content returned."
      },
      "CrudList": {
        "description": "Array of table rows.",
        "content": {
          "application/json": {
            "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CrudItem" } }
          }
        }
      },
      "CrudSingle": {
        "description": "A single table row.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/CrudItem" }
          }
        }
      },
      "CrudCreated": {
        "description": "Created. Returns affected records.",
        "content": {
          "application/json": {
            "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CrudItem" } }
          }
        }
      },
      "CrudUpdated": {
        "description": "Updated. Returns the updated record.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/CrudItem" }
          }
        }
      }
    },
    "requestBodies": {
      "CrudItemBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/CrudItem" }
          }
        }
      }
    }
  },
  "paths": {
    "/version": {
      "get": {
        "tags": ["System"],
        "summary": "Get API version",
        "operationId": "getVersion",
        "responses": {
          "200": {
            "description": "Version string",
            "content": {
              "application/json": {
                "schema": { "type": "string", "example": "4.0.0" }
              }
            }
          }
        }
      }
    },

    "/presenters": {
      "get": {
        "tags": ["Presenters"],
        "summary": "List presenter names",
        "operationId": "getPresenters",
        "responses": {
          "200": {
            "description": "List of presenter names and IDs",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer" },
                    "name": { "type": "string" }
                  }
                } }
              }
            }
          }
        }
      }
    },

    "/events": {
      "get": {
        "tags": ["Events"],
        "summary": "List events",
        "operationId": "getEvents",
        "parameters": [
          {
            "name": "has_videos",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "Filter whether events have videos of presentations."
          }
        ],
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Event" } }
              }
            }
          }
        }
      }
    },

    "/videos": {
      "get": {
        "tags": ["Videos"],
        "summary": "Search and list videos",
        "operationId": "listVideos",
        "description": "Returns a paginated envelope of video results. All responses use the envelope format with `data`, pagination metadata, and navigation links.",
        "parameters": [
          {
            "name": "event_shortname",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by event shortname"
          },
          {
            "name": "presenter",
            "in": "query",
            "schema": { "type": "array", "items": { "type": "integer" } },
            "style": "form",
            "explode": false,
            "description": "Filter by presenter IDs (comma-separated)"
          },
          {
            "name": "search",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Full-text search across titles, descriptions, presenter names, and event names"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": { "type": "string", "enum": ["relevance", "newest", "oldest"] },
            "description": "Sort order. Defaults to `relevance` when `search` is supplied, otherwise `newest`."
          },
          { "$ref": "#/components/parameters/PerPage" },
          { "$ref": "#/components/parameters/Page" }
        ],
        "responses": {
          "200": {
            "description": "Paginated video results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedVideos" }
              }
            }
          }
        }
      }
    },

    "/videos/{youtube_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/YoutubeId" }
      ],
      "get": {
        "tags": ["Videos"],
        "summary": "Get a single video",
        "operationId": "getVideo",
        "responses": {
          "200": {
            "description": "A single video object",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Video" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/videos/{youtube_id}/recommendations": {
      "parameters": [
        { "$ref": "#/components/parameters/YoutubeId" }
      ],
      "get": {
        "tags": ["Videos"],
        "summary": "Get video recommendations",
        "operationId": "getRecommendations",
        "parameters": [
          {
            "name": "n",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "default": 5 },
            "description": "Number of recommendations to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of recommended videos",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Video" } }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/table/person": {
      "get": {
        "tags": ["Table CRUD"],
        "summary": "List persons",
        "operationId": "listPersons",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/CrudList" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Table CRUD"],
        "summary": "Create a person",
        "operationId": "createPerson",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/CrudItemBody" },
        "responses": {
          "201": { "$ref": "#/components/responses/CrudCreated" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/table/person/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/TableId" }],
      "get": {
        "tags": ["Table CRUD"],
        "summary": "Get a person by ID",
        "operationId": "getPerson",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/CrudSingle" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["Table CRUD"],
        "summary": "Update a person",
        "operationId": "updatePerson",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/CrudItemBody" },
        "responses": {
          "200": { "$ref": "#/components/responses/CrudUpdated" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Table CRUD"],
        "summary": "Delete a person",
        "operationId": "deletePerson",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "204": { "$ref": "#/components/responses/NoContent" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/table/organisation": {
      "get": {
        "tags": ["Table CRUD"],
        "summary": "List organisations",

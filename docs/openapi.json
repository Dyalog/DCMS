        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "204": { "$ref": "#/components/responses/NoContent" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/table/event": {
      "get": {
        "tags": ["Table CRUD"],
        "summary": "List events (raw table)",
        "operationId": "listEventRows",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/CrudList" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Table CRUD"],
        "summary": "Create an event",
        "operationId": "createEvent",
        "security": [{ "ApiKeyAuth": [] }],

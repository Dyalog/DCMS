      "post": {
        "tags": ["Table CRUD"],
        "summary": "Create a presentation category",
        "operationId": "createPresentationCategory",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/CrudItemBody" },

      "get": {
        "tags": ["Table CRUD"],
        "summary": "Get an event by ID",
        "operationId": "getEventRow",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/CrudSingle" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["Table CRUD"],
        "summary": "Update an event",
        "operationId": "updateEvent",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": { "$ref": "#/components/requestBodies/CrudItemBody" },

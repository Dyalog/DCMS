#!/usr/bin/dyalogscript DYALOG_INITSESSION=1
‚çù Install the Tatin and NuGet application dependencies
‚éï‚Üê'Installing application dependencies...'

root‚Üê2 ‚éïNQ # 'GetEnvironment' 'APP_DIR'
pkg‚Üêroot,'/packages'
nuget‚Üêroot,'/nuget-packages'

:Trap 0
    ‚éïSE.Tatin.ReInstallDependencies pkg
    ‚éïSE.Tatin.LoadPackages 'NuGet' ‚éïTHIS
    NuGet.Publish nuget
    ‚éï‚Üê'Application dependencies installed in ',pkg,' and ',nuget
    ‚éïOFF 0
:Else
    ‚éï‚Üê'Could not install dependencies.'
    ‚éï‚Üê1‚éïJSON‚éïOPT'Compact'0‚ä¢‚éïDMX
    ‚éïOFF 1
:EndTrap

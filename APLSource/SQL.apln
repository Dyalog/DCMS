    ‚ąá msg‚ÜźCatch msg;en;w
      en‚Üź‚äÉmsg
      :If 0<en       ‚ćĚ Server error if database operation fails
          {}SQA.Close cur
          :If 2006=2 2‚äÉmsg   ‚ćĚ SQL server has gone away
              Debug'> SQL SERVER WAS AWAY FOR QUERY: ',‚ćē‚éēTS
              SQA.Close db
              Connect ##.GetEnv¬®'SQL_DATABASE' 'SQL_PASSWORD' 'SQL_USER'
          :Else
              ‚éēSIGNAL‚äā('EN' 500)('Vendor' 'DCMS')('Message'(3‚äÉmsg))
          :EndIf
      :ElseIf 0>en

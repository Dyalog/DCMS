    :section SCHEMA_PROCESSING

      StatementsFromSchema‚Üź{
     ‚ćĚ ‚ćĶ: Simple char vec        :: path to .sql file
     ‚ćĚ ‚Üź: Nested vec of char vec :: SQL statements
          (txt enc nl)‚Üź‚éēNGET ‚ćĶ
          sql‚Üź'/\*.+\*/' '--[^\n]*'‚éēR''‚äĘtxt   ‚ćĚ Remove comments
          sql‚Üź' '@(‚ąä‚ąė(‚éēUCS nl))sql            ‚ćĚ Replace newlines with spaces
          sql‚Üź' '‚ąė(1‚Üď,‚äĘ‚ć§/‚ć®1(‚äĘ‚ą®‚ĆĹ)0,‚Č†)sql       ‚ćĚ Remove leading, trailing, duplicate blanks
          ';'(‚Č†‚äÜ‚äĘ)sql                         ‚ćĚ Split on semicolons
      }

    ‚ąá msg‚ÜźSetupSchema dum;Run;batch;create_migrations;folder;latest;migration;migrations;order;schema_definitions;sequence;statements
      create_migrations‚Üź‚äÉ‚éēNGET ##.GLOBAL.app_dir,'/sql/migrations.sql'
      Do create_migrations
     
      folder‚Üź##.GetEnv'SCHEMA_DEFS'
      schema_definitions‚Üź'.*\d+-.*.sql'‚éēS'&'‚äÉ0(‚éēNINFO‚ć†'Wildcard' 1)folder
      sequence‚Üź‚ąä2‚äÉ¬®‚éēVFI¬®‚äÉ¬®'-'(‚Č†‚äÜ‚äĘ)¬®2‚äÉ¬®‚éēNPARTS¬®schema_definitions
      order‚Üź‚ćčsequence
      schema_definitions‚Üźschema_definitions[order]
      sequence‚Üźsequence[order]
     
      :If 0=‚äÉlatest‚ÜźSQA.Do db'select max(batch) from migrations'
          (migrations sequence)‚Üź(schema_definitions sequence)‚Üď‚ć®¬®3 1‚äÉlatest   ‚ćĚ Database exists, apply after most recent migration
      :Else
          migrations‚Üźschema_definitions
      :EndIf
      Run‚Üź{
          0=‚äÉr‚ÜźSQA.Do db ‚ćĶ:‚ć¨
          ‚éē‚Üź'Migration failed: ',‚ćļ
          ‚éē‚Üź'  Statement: ',‚ćĶ
          ‚éē‚Üź'  Error: ',,‚ćē3‚äÉr
      }
      :For (migration batch) :InEach (migrations sequence)
          ##.Log migration
          statements‚ÜźStatementsFromSchema migration
          migration‚ąėRun¬®statements
          SQA.Do db'insert into migrations (`migration`,`batch`) values (:file<C255:,:num<I:);'migration batch
      :EndFor
      msg‚Üź'Finished SetupSchema'
    ‚ąá

      ProcessTableInformation‚Üź{
          table_information‚Üź2‚äÉSQA.Columns db
          h‚Üź1‚Ć∑table_information ‚čĄ d‚Üź1‚Üďtable_information   ‚ćĚ Header; Data
          ##.GLOBAL.tables‚Üź‚ą™d[;h‚ć≥‚äā'TABLE_NAME']
          tc‚Üź‚éēCSV(##.GLOBAL.app_dir,'/sql/type_conversions.csv')‚ć¨ 4  ‚ćĚ Type conversions matrix
          cz‚Üźd[;h‚ć≥‚äā'COLUMN_SIZE']
          tp‚Üźd[;h‚ć≥‚äā'DATA_TYPE']
          ti‚Üź(‚äĘ/tc)‚ć≥tp
          ‚ą®/ti>‚ČĘtc:‚éēSIGNAL‚äā('EN' 101)('Vendor' 'DCMS')('Message'('Unknown column types in rows ',‚ćē‚ćłti>‚ČĘtc))
          tn‚Üźtc[ti;2]
          sqat‚Üź('<'‚ąė=‚äā‚äĘ)‚ąä(‚ćē¬®cz/‚ć®'‚éē'‚ąė‚ąä¬®tn)@('‚éē'‚ąė=)‚ąätn   ‚ćĚ Replace ‚éē with numeric field widths (COLUMN_SIZE) in SQAPL type definitions
          t‚Üźd[;h‚ć≥‚äā'TABLE_NAME']
          ##.GLOBAL.tables‚Üź‚ą™t
          ##.GLOBAL.types‚Üźt‚äĘ‚ąė‚äā‚Ćłtp
          ##.GLOBAL.type_sqapl‚Üźt‚äĘ‚ąė‚äā‚Ćłsqat
          ##.GLOBAL.columns‚Üźt‚äĘ‚ąė‚äā‚Ćłd[;h‚ć≥‚äā'COLUMN_NAME']
          ##.GLOBAL.lengths‚Üźt‚äĘ‚ąė‚äā‚Ćłcz
          fk_rows‚ÜźDo'SELECT TABLE_NAME, COLUMN_NAME, REFERENCED_TABLE_NAME, REFERENCED_COLUMN_NAME FROM information_schema.KEY_COLUMN_USAGE WHERE TABLE_SCHEMA=DATABASE() AND REFERENCED_TABLE_NAME IS NOT NULL ORDER BY TABLE_NAME, ORDINAL_POSITION'
          fk_keys‚Üźfk_rows[;1] ‚čĄ fk_triples‚Üź‚Üďfk_rows[;2 3 4]   ‚ćĚ keys: TABLE_NAME; triples: (col ref_table ref_column) per FK column
          fks‚Üź(‚ČĘ##.GLOBAL.tables)‚ćī‚äā‚ć¨                          ‚ćĚ one slot per table, default empty
          fks[##.GLOBAL.tables‚ć≥‚ą™fk_keys]‚Üźfk_keys‚äĘ‚ąė‚äā‚Ćłfk_triples
          ##.GLOBAL.foreign_keys‚Üźfks
          'Processed table information'
      }


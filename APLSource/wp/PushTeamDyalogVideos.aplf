 sql‚Üê'SELECT r.media_id,r.ytid,r.title,r.thumbnail,r.description,r.presented_at,r.event_link,r.event_title,r.pers_id FROM '
 sql,‚Üê'(SELECT yt.id AS media_id, yt.youtube_id AS ytid, yt.title AS title, yt.thumbnail AS thumbnail, yt.description AS description, pres.presented_at AS presented_at, event.url_slug AS event_link, event.title AS event_title, per.id AS pers_id, '
 sql,‚Üê'ROW_NUMBER() OVER (PARTITION BY per.id ORDER BY pres.presented_at DESC) AS rank '
 sql,‚Üê'FROM person AS per LEFT JOIN presenter ON per.id = presenter.person_id '
 sql,‚Üê'LEFT JOIN presentation AS pres ON presenter.presentation_id = pres.id '
 sql,‚Üê'LEFT JOIN event ON pres.event_id = event.id '
 sql,‚Üê'LEFT JOIN presentation_media AS pm ON pres.id = pm.presentation_id '
 sql,‚Üê'LEFT JOIN youtube_video AS yt ON pm.media_id = yt.id '
 sql,‚Üê'WHERE pm.type = "youtube_video") r '

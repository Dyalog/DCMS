{
	Extend: "dcms.dcfg",
	Settings: {
		PUBLIC_URL:    "http://test.url",   // For pagination links
		SERVICE_PORT:  8081,                // Used to start Stark/Jarvis server
		LOGGING:      1,
		SUSPEND:      1,

		YOUTUBE:      "http://localhost:8088/",

		LX:           "⎕←⎕SE.Link.Create 'DCMS' '[APP_DIR]/APLSource' ⋄\
					   ⎕←⎕SE.Link.Create 'Admin' '[APP_DIR]/Admin'    ⋄\
					   DCMS.Setup ⋄ DCMS.Run [LOGGING] [SUSPEND] [TRACE]"
	}
}
